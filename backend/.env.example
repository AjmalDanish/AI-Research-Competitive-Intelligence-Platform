# ==================== Application ====================
APP_NAME=AI Website Intelligence Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ==================== Database ====================
DATABASE_NAME=ai_website_intelligence
TEST_DATABASE_NAME=ai_website_intelligence_test
DATABASE_USER=ai_user
DATABASE_PASSWORD=ai_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ==================== API ====================
API_V1_PREFIX=/api/v1
API_TITLE=AI Website Intelligence Platform API
API_DESCRIPTION=API for analyzing websites and extracting business intelligence
API_VERSION=0.1.0
DOCS_ENABLED=True
DOCS_URL=/docs
REDOC_URL=/redoc

# ==================== Security ====================
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*

# ==================== Crawler Configuration (Milestone 3) ====================
# User Agent for crawler requests
CRAWLER_USER_AGENT=AI-Website-Intelligence-Platform/0.1 (+https://github.com/AjmalDanish/AI-Research-Competitive-Intelligence-Platform)

# Timeout Settings (seconds)
CRAWLER_TIMEOUT_URL_VALIDATION=5
CRAWLER_TIMEOUT_ROBOTS_CHECK=10
CRAWLER_TIMEOUT_CRAWL=30
CRAWLER_TIMEOUT_OVERALL=60

# Retry Settings
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_INITIAL_DELAY=1
CRAWLER_RETRY_MULTIPLIER=2.0
CRAWLER_RETRY_MAX_DELAY=10

# Crawler Selection
CRAWLER_DEFAULT_TYPE=playwright

# Browser Configuration (Playwright)
CRAWLER_BROWSER_HEADLESS=True
CRAWLER_BROWSER_TIMEOUT=30000
CRAWLER_BROWSER_VIEWPORT_WIDTH=1920
CRAWLER_BROWSER_VIEWPORT_HEIGHT=1080

# Content Configuration
CRAWLER_MAX_CONTENT_LENGTH=10485760
CRAWLER_FOLLOW_REDIRECTS=True
CRAWLER_MAX_REDIRECTS=5

# robots.txt Configuration
CRAWLER_RESPECT_ROBOTS_TXT=True
CRAWLER_ROBOTS_CACHE_TTL=3600

# ==================== Future AI Providers ====================
# OpenAI API key (Milestone 7)
OPENAI_API_KEY=

# Anthropic API key (Milestone 7)
ANTHROPIC_API_KEY=